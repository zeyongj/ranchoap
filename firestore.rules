// firestore.rules
// Deploy with: firebase deploy --only firestore:rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Anyone authenticated (we handle auth in-app) can read/write
    // For production you'd want stricter rules, but for internal tool this is fine
    match /{document=**} {
      allow read, write: if true;
    }
  }
}
